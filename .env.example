NEOSHELL_ADMIN_USERNAME=admin
NEOSHELL_ADMIN_PASSWORD=replace-me-with-a-long-random-secret
NEOSHELL_DATABASE_PATH=./data/neoshell.sqlite
NEOSHELL_WORKSPACE_ROOT=.
NEOSHELL_SPILL_DIRECTORY=./data/spills
NEOSHELL_SESSION_COOKIE_NAME=neoshell_session
NEOSHELL_SESSION_TTL_HOURS=168
NEOSHELL_SECURE_COOKIES=false
NEOSHELL_LOG_LEVEL=info
NEOSHELL_HOST=0.0.0.0
NEOSHELL_PORT=4000
NEOSHELL_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://127.0.0.1:3002,http://localhost:5173,http://127.0.0.1:5173
NEOSHELL_API_PROXY_TARGET=http://127.0.0.1:4000
NEOSHELL_PROVIDER_TIMEOUT_MS=60000
NEOSHELL_COMMAND_TIMEOUT_MS=45000

# Single-provider shortcut
NEOSHELL_PROVIDER_ID=default
NEOSHELL_PROVIDER_LABEL=Primary Provider
NEOSHELL_PROVIDER_BASE_URL=https://api.example.com/v1
NEOSHELL_PROVIDER_MODEL=provider/chat-model
NEOSHELL_PROVIDER_API_KEY=

# Optional multi-provider JSON config. If set, these override the single-provider fields above.
# NEOSHELL_PROVIDERS_JSON=[{"providerId":"primary","label":"Primary Provider","kind":"openai_compatible","baseUrl":"https://api.example.com/v1","model":"provider/chat-model","supportsReasoning":true},{"providerId":"backup","label":"Backup Provider","kind":"openai_compatible","baseUrl":"https://api.backup.example.com/v1","model":"provider/fallback-model","supportsReasoning":false}]
# NEOSHELL_PROVIDER_SECRETS_JSON={"primary":"provider-api-key","backup":"backup-api-key"}

# Optional direct browser API base URL. Prefer same-origin proxy when possible.
# VITE_NEOSHELL_API_BASE_URL=http://127.0.0.1:4000
