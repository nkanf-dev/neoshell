{
  "name": "neoshell",
  "private": true,
  "version": "0.1.0",
  "description": "Browser-first PowerShell agent control plane with streaming observability and pluggable providers.",
  "homepage": "https://github.com/nkanf-dev/neoshell",
  "bugs": {
    "url": "https://github.com/nkanf-dev/neoshell/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nkanf-dev/neoshell.git"
  },
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --workspaces build",
    "dev": "bun run scripts/dev.ts",
    "dev:server": "bun --cwd apps/server run dev",
    "dev:web": "bun --cwd apps/web run dev",
    "lint": "bun run --workspaces lint",
    "stop:dev": "powershell -NoLogo -ExecutionPolicy Bypass -File ./scripts/stop-dev.ps1",
    "test": "bun run --workspaces test",
    "typecheck": "bun run --workspaces typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.35.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "tsx": "^4.20.5",
    "vitest": "^3.2.4"
  }
}
